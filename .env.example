# Root env for DOCKER (copy to .env, used by `docker compose` / `make up` for interpolation).
# For host dev without Docker (`make dev`), use backend/.env.example -> backend/.env instead.
OPENAI_API_KEY=
# OPENAI_MODEL is the single-model default for BOTH agents (classifier + summarizer).
# Any OpenAIModel value (app/agent/llm.py): gpt-4o-mini | gpt-4o | gpt-4.1 | o3 | o4-mini ...
OPENAI_MODEL=gpt-4o-mini
# Optional per-agent ORDERED fallback chains (CSV, first = primary). Leave unset to use OPENAI_MODEL.
# CLASSIFIER_MODELS=gpt-4o,gpt-4o-mini
# SUMMARIZER_MODELS=gpt-4o-mini

# Optional LLM tracing (leave blank to disable — the app still runs).
LOGFIRE_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# true = JSON logs (good for log aggregation in containers); false = console (see backend/.env.example).
LOG_JSON=true
