# Backend env for HOST development only (copy to backend/.env, used by `make dev`/`make backend`).
# For Docker (`make up`), edit the ROOT .env instead — compose injects it into the container.
OPENAI_API_KEY=
# OPENAI_MODEL is the single-model default for BOTH agents. Any value from OpenAIModel in
# app/agent/llm.py, e.g. gpt-4o-mini | gpt-4o | gpt-4.1 | gpt-4.1-mini | o3 | o3-mini | o4-mini
OPENAI_MODEL=gpt-4o-mini
# Optional per-agent ORDERED fallback chains (CSV, first = primary). Leave unset to use OPENAI_MODEL.
# A stronger primary like gpt-4o only works if your key has access — otherwise it 403s.
# CLASSIFIER_MODELS=gpt-4o,gpt-4o-mini
# SUMMARIZER_MODELS=gpt-4o-mini

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qtov
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2/studies

# Optional LLM tracing (leave blank to disable; app still runs)
LOGFIRE_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# false = human-readable console logs (handy for host dev); true = JSON (as Docker uses).
LOG_JSON=false
LOG_LEVEL=INFO
